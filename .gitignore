# sinaq project gitignore

# Ignore everything by default
*

# Allow the sinaq directory and its contents
!sinaq/
!sinaq/**

# Exclude build artifacts and dependencies inside sinaq
sinaq/node_modules/
sinaq/.next/
sinaq/out/
sinaq/build/
sinaq/.env*

# Allow these root files if they exist and are needed
!.gitignore
!README.md
